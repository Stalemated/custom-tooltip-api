{
	"schemaVersion": 1,
	"id": "customtooltips",
	"version": "${version}",
	"name": "Custom Tooltip API",
	"description": "A completely customizable, tag-based tooltip manager for developers and modpack makers.",
	"authors": [
		"Stalemated"
	],
	"contact": {
		"homepage": "https://www.curseforge.com/minecraft/mc-mods/custom-tooltip-api",
		"sources": "https://github.com/Stalemated/custom-tooltip-api",
		"issues": "https://github.com/Stalemated/custom-tooltip-api/issues"
	},
	"license": "MIT",
	"icon": "assets/custom-tooltip-api/icon.jpg",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.stalemated.customtooltips.CustomTooltipApiClient"
		],
		"modmenu": [
			"com.stalemated.customtooltips.ModMenuIntegration"
		]
	},
	"mixins": [
		"customtooltips.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.10",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}